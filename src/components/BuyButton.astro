---
// One place for the store CTA. While AMAZON_URL is empty it renders a
// non-clickable availability line, so no page ever ships a dead link.
import { AMAZON_URL, AVAILABILITY } from '../consts';

interface Props {
  label?: string;
  soon?: string;
  block?: boolean;
}
const { label = 'Buy now', soon = AVAILABILITY, block = false } = Astro.props;
const cls = block ? 'btn btn-primary' : 'btn btn-primary';
---
{AMAZON_URL
  ? <a class={cls} href={AMAZON_URL} target="_blank" rel="noopener">{label}</a>
  : <span class="btn" aria-disabled="true">{soon}</span>}
