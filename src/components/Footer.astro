---
import { SITE, NAV, SOCIAL, CLOSER } from '../consts';
const year = 2026;
const socials = Object.entries(SOCIAL).filter(([, url]) => url);
---

<footer class="site-footer">
  <div class="wrap site-footer__inner">
    <div class="site-footer__brand">
      <img class="site-footer__logo" src="/brand/logo-white.svg" alt={`${SITE.title} — ${SITE.descriptor}`} width="260" height="56" />
      <p class="site-footer__closer">{CLOSER}</p>
    </div>

    <nav class="site-footer__nav" aria-label="Footer">
      {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href={`mailto:${SITE.email}`}>Contact</a>
    </nav>
  </div>

  <div class="wrap site-footer__legal">
    <span>&copy; {year} {SITE.title}. Naramata, British Columbia.</span>
    {socials.length > 0 && (
      <span class="site-footer__social">
        {socials.map(([name, url]) => <a href={url} target="_blank" rel="noopener">{name}</a>)}
      </span>
    )}
  </div>
</footer>

<style>
  .site-footer { background: var(--ink); color: var(--paper); margin-top: var(--section-y); }
  .site-footer__inner { display: flex; flex-wrap: wrap; gap: 2rem; justify-content: space-between; padding-block: 3rem 1.5rem; }
  .site-footer__logo { height: 44px; width: auto; display: block; }
  .site-footer__closer { color: #cfc6d2; margin: 0.9rem 0 0; font-style: italic; }
  .site-footer__nav { display: flex; flex-direction: column; gap: 0.5rem; }
  .site-footer__nav a { color: #e7e0ea; text-decoration: none; font-size: 0.95rem; }
  .site-footer__nav a:hover { color: var(--gold); }
  .site-footer__legal { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: space-between; padding-block: 1.25rem; border-top: 1px solid rgba(255,255,255,0.12); font-size: 0.82rem; color: #b6acbb; }
  .site-footer__social { display: flex; gap: 1rem; text-transform: capitalize; }
  .site-footer__social a { color: #b6acbb; }
  .site-footer__social a:hover { color: var(--gold); }
</style>
