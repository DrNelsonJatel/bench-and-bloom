---
// Bench & Bloom logo mark: a stylised lavender sprig. Inline SVG so it scales
// crisply and recolours per context (pass bud/stem). Default = brand colours.
interface Props {
  size?: number;
  bud?: string;
  stem?: string;
  class?: string;
}
const { size = 32, bud = '#5A4A78', stem = '#8B9A7D', class: cls = '' } = Astro.props;
const h = Math.round(size * 1.3);
---
<svg
  width={size}
  height={h}
  viewBox="0 0 40 52"
  class={cls}
  role="img"
  aria-label="Bench & Bloom"
  style={`--bud:${bud};--stem:${stem}`}
>
  <!-- stem + leaves -->
  <path d="M20 51 L20 27" stroke="var(--stem)" stroke-width="2.4" stroke-linecap="round" fill="none" />
  <path d="M20 40 C 15 39, 12 36, 11 32" stroke="var(--stem)" stroke-width="2" stroke-linecap="round" fill="none" />
  <path d="M20 43 C 25 42, 28 39, 29 35" stroke="var(--stem)" stroke-width="2" stroke-linecap="round" fill="none" />
  <!-- bud spike -->
  <g fill="var(--bud)">
    <ellipse cx="20" cy="5" rx="1.7" ry="2.4" />
    <ellipse cx="20" cy="9" rx="2" ry="2.7" />
    <ellipse cx="15.6" cy="11" rx="1.8" ry="2.5" />
    <ellipse cx="24.4" cy="11" rx="1.8" ry="2.5" />
    <ellipse cx="20" cy="13.5" rx="2.1" ry="2.8" />
    <ellipse cx="14.2" cy="15.6" rx="1.9" ry="2.6" />
    <ellipse cx="25.8" cy="15.6" rx="1.9" ry="2.6" />
    <ellipse cx="20" cy="18.1" rx="2.2" ry="2.9" />
    <ellipse cx="13.6" cy="20.3" rx="2" ry="2.7" />
    <ellipse cx="26.4" cy="20.3" rx="2" ry="2.7" />
    <ellipse cx="20" cy="22.6" rx="2.2" ry="2.9" />
    <ellipse cx="15.2" cy="25" rx="2" ry="2.6" />
    <ellipse cx="24.8" cy="25" rx="2" ry="2.6" />
  </g>
</svg>
