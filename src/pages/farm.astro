---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';

const title = 'Our Farm';
const description =
  'Bench & Bloom is a second-generation family farm on the Naramata Bench above Okanagan Lake: ' +
  'three acres, two of grapes for Hillside Winery and a half-acre of lavender. Owner-operator Nelson Jatel.';
---

<Base title={title} description={description}>
  <section class="hero hero--photo" style="--hero-img:url('/images/field-rows-evening.jpg')">
    <div class="wrap hero__inner">
      <p class="eyebrow">{SITE.descriptor}</p>
      <h1>A half-acre on the bench.</h1>
      <p class="hero__lede">
        We grow lavender on a small plot on the Naramata Bench, the same warm, dry slopes
        that ripen the Okanagan&rsquo;s wine.
      </p>
    </div>
  </section>

  <section class="section wrap split">
    <img class="media" src="/images/lavender-field-rows-2.jpg" width="1400" height="1050"
      loading="lazy" decoding="async"
      alt="Rows of lavender on the Naramata Bench under a blue sky, orchard behind" />
    <div>
      <p class="eyebrow">The place</p>
      <h2>Wine country, in lavender.</h2>
      <p>
        The Naramata Bench is a narrow shelf of land above Okanagan Lake, lined with
        wineries and orchards. The heat, the light and the long dry summers that make the
        grapes also suit lavender. Our half-acre sits among it, a small operation by
        design.
      </p>
      <p>
        We grow a single variety, <strong>Grosso</strong>, and harvest once a year in the
        heat of midsummer. Everything is made in small batches we can stand behind.
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="wrap split">
      <div>
        <p class="eyebrow">How it is made</p>
        <h2>From row to bottle.</h2>
        <p>
          We cut the lavender by hand at peak bloom, dry the bundles, and strip the buds. Those
          buds, never an essential oil or an extract, are what we steep into the syrup, together
          with butterfly pea flower for a natural blue. We watch the steep closely, because the
          difference between floral and soapy is a matter of minutes.
        </p>
        <p>
          A roadside stand is in the works for the bloom season. For now, the syrup travels
          to you through Amazon.ca. <a href="/syrup">Read more about the syrup</a>, or
          <a href="/visit">plan a visit</a>.
        </p>
      </div>
      <img class="media" src="/images/harvest-on-the-tractor.jpg" width="1400" height="1050"
        loading="lazy" decoding="async"
        alt="Harvesting cut lavender on the John Deere, the Okanagan valley behind" />
    </div>
  </section>

  <section class="section wrap">
    <div class="split split--founder">
      <div>
        <p class="eyebrow">The family behind it</p>
        <h2>Two generations on the bench.</h2>
        <p>
          Bench &amp; Bloom is a second-generation family farm. Nelson Jatel grew up here, on three
          acres above Okanagan Lake on the Naramata Bench. Two of those acres grow grapes for
          <strong>Hillside Winery</strong>; a half-acre is our lavender. The same warm, dry slopes that
          ripen the grapes give the lavender its bold aroma.
        </p>
        <p>
          It is small and hands-on, worked by hand harvest by harvest, alongside family. The syrup
          carries the place it comes from.
        </p>
        <p class="byline">
          Nelson Jatel, owner and operator &#183;
          <a href="https://www.linkedin.com/in/nelsonjatel/" target="_blank" rel="noopener">LinkedIn</a>
        </p>
      </div>
      <img class="media" src="/images/founder-nelson.jpg" width="1125" height="1500"
        loading="lazy" decoding="async"
        alt="Nelson Jatel, owner and operator of Bench & Bloom, on the farm above Okanagan Lake" />
    </div>

    <div class="duo">
      <img class="media" src="/images/founder-two-generations.jpg" width="1125" height="1500"
        loading="lazy" decoding="async"
        alt="Nelson Jatel and his father by the lavender field, two generations of the farm" />
      <img class="media" src="/images/vineyard-lake.jpg" width="1500" height="1125"
        loading="lazy" decoding="async"
        alt="The family vineyard on the Naramata Bench above Okanagan Lake, grapes grown for Hillside Winery" />
    </div>
  </section>
</Base>

<style>
  .split--founder { align-items: start; }
  @media (min-width: 820px) { .split--founder { grid-template-columns: 1.25fr 0.75fr; } }
  .byline { color: var(--ink-soft); font-size: 0.92rem; margin-top: 1.25rem; }
  .duo { display: grid; gap: var(--gap); grid-template-columns: 1fr; margin-top: clamp(1.5rem, 4vw, 2.5rem); }
  @media (min-width: 700px) { .duo { grid-template-columns: 1fr 1fr; } }
</style>
