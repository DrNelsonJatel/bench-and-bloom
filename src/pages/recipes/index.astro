---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const recipes = (await getCollection('recipes')).sort((a, b) => a.data.order - b.data.order);
const anchor = recipes.find((r) => r.data.kind === 'anchor');
const drinks = recipes.filter((r) => r.data.kind !== 'anchor');

const title = 'Lavender Cocktails & Recipes';
const description =
  'Lavender simple syrup recipes for gin cocktails and mocktails: gin fizz, French 75, ' +
  'lemonade and an iced lavender latte. Mocktail or cocktail, every time.';
---

<Base title={title} description={description}>
  <section class="hero hero--photo" style="--hero-img:url('/images/lavender-bees.jpg')">
    <div class="wrap hero__inner">
      <p class="eyebrow">Mix it</p>
      <h1>Lavender, made for the glass.</h1>
      <p class="hero__lede">
        Gin is the anchor, but every pour works as a mocktail too. Start with the base
        syrup, then take it anywhere.
      </p>
    </div>
  </section>

  {anchor && (
    <section class="section wrap">
      <a class="feature" href={`/recipes/${anchor.id}`}>
        <div>
          <p class="eyebrow">Start here</p>
          <h2 class="mt-0">{anchor.data.title}</h2>
          <p>{anchor.data.description}</p>
          <span class="feature__link">Read the how-to</span>
        </div>
        <img class="media" src="/images/harvest-field.jpg" width="1400" height="1050"
          loading="lazy" decoding="async"
          alt="Cut lavender hauled from the field, on its way to becoming syrup" />
      </a>
    </section>
  )}

  <section class="section section--surface">
    <div class="wrap">
      <p class="eyebrow">The drinks</p>
      <h2>Pour something</h2>
      <div class="cards">
        {drinks.map((r) => (
          <a class="card card--link" href={`/recipes/${r.id}`}>
            <p class="eyebrow">{r.data.kind === 'mocktail' ? 'Mocktail or cocktail' : r.data.spirit ?? 'Cocktail'}</p>
            <h3>{r.data.title}</h3>
            <p>{r.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .feature { display: grid; gap: clamp(1.5rem, 5vw, 3rem); grid-template-columns: 1fr; align-items: center; text-decoration: none; color: inherit; }
  @media (min-width: 820px) { .feature { grid-template-columns: 1.1fr 0.9fr; } }
  .feature h2 { color: var(--lavender-deep); }
  .feature p { color: var(--ink-soft); }
  .feature__link { color: var(--lavender-deep); font-weight: 600; }
  .feature:hover .feature__link { color: var(--gold-deep); }
  .feature__media { aspect-ratio: 16 / 11; border-radius: var(--radius); border: 1px solid var(--line);
    background: radial-gradient(90% 90% at 30% 20%, rgba(124,106,156,0.28), transparent 60%), linear-gradient(160deg, var(--sage), var(--lavender));
    display: grid; place-items: center; color: rgba(255,255,255,0.85); font-size: 0.78rem; letter-spacing: 0.06em; text-transform: uppercase; }
  .card--link { text-decoration: none; color: inherit; transition: border-color 0.15s ease, transform 0.15s ease; }
  .card--link:hover { border-color: var(--gold); transform: translateY(-2px); }
</style>
