---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const recipes = (await getCollection('recipes')).sort((a, b) => a.data.order - b.data.order);
const anchor = recipes.find((r) => r.data.kind === 'anchor');
const drinks = recipes.filter((r) => r.data.kind !== 'anchor');

const signatures = drinks.filter((r) => r.data.signature);
const rest = drinks.filter((r) => !r.data.signature);
const gin = rest.filter((r) => r.data.spirit === 'Gin');
const vodka = rest.filter((r) => r.data.spirit === 'Vodka');
const noalc = rest.filter((r) => r.data.kind === 'mocktail');

const groups = [
  { label: 'Signature serves', note: 'Our own, named for the bench. Watch it bloom.', items: signatures },
  { label: 'The classics', note: 'Gin', items: gin },
  { label: 'Vodka', note: 'Vodka', items: vodka },
  { label: 'No alcohol', note: 'Mocktail or cocktail', items: noalc },
].filter((g) => g.items.length);

const tag = (r: any) =>
  r.data.signature ? 'Signature' : r.data.kind === 'mocktail' ? 'Mocktail or cocktail' : r.data.spirit ?? 'Cocktail';

const title = 'Lavender Cocktails & Recipes';
const description =
  'Lavender simple syrup recipes for gin and vodka cocktails and mocktails: the colour-changing ' +
  'Naramata Sunset, gin fizz, French 75, Moscow mule, lemonade and an iced lavender latte. ' +
  'Add citrus and watch it bloom from blue to pink.';
---

<Base title={title} description={description}>
  <section class="hero hero--photo" style="--hero-img:url('/images/lavender-bees.jpg')">
    <div class="wrap hero__inner">
      <p class="eyebrow">Mix it</p>
      <h1>Lavender, made for the glass.</h1>
      <p class="hero__lede">
        Gin, vodka, sparkling or zero-proof. Pour it blue, add a squeeze of citrus, and watch it
        bloom to pink. Start with the base syrup, then take it anywhere.
      </p>
    </div>
  </section>

  {anchor && (
    <section class="section wrap">
      <a class="feature" href={`/recipes/${anchor.id}`}>
        <div>
          <p class="eyebrow">Start here</p>
          <h2 class="mt-0">{anchor.data.title}</h2>
          <p>{anchor.data.description}</p>
          <span class="feature__link">Read the how-to</span>
        </div>
        <img class="media" src="/images/harvest-field.jpg" width="1400" height="1050"
          loading="lazy" decoding="async"
          alt="Cut lavender hauled from the field, on its way to becoming syrup" />
      </a>
    </section>
  )}

  <section class="section section--surface">
    <div class="wrap">
      {groups.map((g, i) => (
        <div class={i > 0 ? 'group' : ''}>
          <p class="eyebrow">{g.note}</p>
          <h2>{g.label}</h2>
          <div class="cards">
            {g.items.map((r) => (
              <a class="card card--link" href={`/recipes/${r.id}`}>
                <p class="eyebrow">{tag(r)}</p>
                <h3>{r.data.title}</h3>
                <p>{r.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .feature { display: grid; gap: clamp(1.5rem, 5vw, 3rem); grid-template-columns: 1fr; align-items: center; text-decoration: none; color: inherit; }
  @media (min-width: 820px) { .feature { grid-template-columns: 1.1fr 0.9fr; } }
  .feature h2 { color: var(--lavender-deep); }
  .feature p { color: var(--ink-soft); }
  .feature__link { color: var(--lavender-deep); font-weight: 600; }
  .feature:hover .feature__link { color: var(--gold-deep); }
  .group { margin-top: clamp(2.25rem, 5vw, 3.5rem); }
  .card--link { text-decoration: none; color: inherit; transition: border-color 0.15s ease, transform 0.15s ease; }
  .card--link:hover { border-color: var(--gold); transform: translateY(-2px); }
  .card--link:hover h3 { color: var(--lavender-deep); }
</style>
