---
import Base from '../layouts/Base.astro';
import BuyButton from '../components/BuyButton.astro';
import { SITE } from '../consts';

const title = 'The Syrup';
const description =
  'Bench & Bloom lavender simple syrup: real Grosso lavender buds steeped and strained, ' +
  'no essential oils, balanced for gin, cocktails and sparkling wine. Grown on the Naramata Bench.';

// Product JSON-LD without Offer until the Amazon.ca listing and price exist.
const productLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Bench & Bloom Lavender Simple Syrup',
  brand: { '@type': 'Brand', name: SITE.title },
  category: 'Cocktail syrup',
  description,
  url: new URL('/syrup', SITE.url).href,
};
---

<Base title={title} description={description}>
  <section class="hero">
    <div class="wrap hero__inner">
      <p class="eyebrow">{SITE.descriptor}</p>
      <h1>Lavender simple syrup, made for the glass.</h1>
      <p class="hero__lede">
        One bottle, three ingredients, and a whole field behind it. Real lavender buds,
        steeped and strained by hand. No essential oils, no synthetic flavour.
      </p>
      <div class="cta-row"><BuyButton /></div>
    </div>
  </section>

  <section class="section wrap split">
    <div>
      <p class="eyebrow">What is in it</p>
      <h2>Three ingredients. Nothing to hide.</h2>
      <p>
        Lavender, cane sugar and water. That is the whole list. We steep our own
        <strong>Grosso</strong> lavender, strain the buds out, and balance the syrup so the
        lavender reads floral, never soapy. That balance is the hard part, and it is the
        part we obsess over.
      </p>
      <p>
        Grosso is the bold, aromatic variety grown for its deep colour and strong scent. It
        gives the syrup enough backbone to carry through a gin and tonic or a glass of
        sparkling wine, where a softer lavender would simply disappear.
      </p>
    </div>
    <div class="split__media" role="img" aria-label="Bench & Bloom lavender syrup bottle, photo coming soon">
      Bottle photo &mdash; coming this bloom
    </div>
  </section>

  <section class="section section--surface">
    <div class="wrap">
      <p class="eyebrow">How to use it</p>
      <h2>Floral, not fussy.</h2>
      <div class="cards">
        <article class="card"><h3>In a cocktail</h3><p>Gin is the natural partner. Try it in a <a href="/recipes/lavender-gin-fizz">Gin Fizz</a> or a <a href="/recipes/lavender-french-75">French 75</a>.</p></article>
        <article class="card"><h3>Without the gin</h3><p>Every drink works as a mocktail. A <a href="/recipes/lavender-lemonade">Lavender Lemonade</a> is the easy crowd-pleaser.</p></article>
        <article class="card"><h3>In your coffee</h3><p>A splash in an <a href="/recipes/lavender-latte">iced lavender latte</a> is the daily-driver use.</p></article>
      </div>
    </div>
  </section>

  <section class="section wrap center">
    <h2>Coming to Amazon.ca this season.</h2>
    <p class="lede" style="margin-inline:auto;">A small first batch. <a href="/#launch">Leave your email</a> and we will tell you the day it goes live.</p>
    <div class="cta-row" style="justify-content:center;"><BuyButton /></div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(productLd)} />
</Base>
