---
import Base from '../layouts/Base.astro';
import BuyButton from '../components/BuyButton.astro';
import { SITE } from '../consts';

const title = 'The Syrup';
const description =
  'Bench & Bloom lavender syrup: real Grosso lavender buds and butterfly pea flower, ' +
  'steeped and strained, no essential oils, no artificial colour. A natural blue that blooms to ' +
  'pink with citrus. Grown on the Naramata Bench.';

// Product JSON-LD without Offer until the Amazon.ca listing and price exist.
const productLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Bench & Bloom Lavender Syrup',
  brand: { '@type': 'Brand', name: SITE.title },
  category: 'Cocktail syrup',
  description,
  url: new URL('/syrup', SITE.url).href,
};
---

<Base title={title} description={description}>
  <section class="hero hero--photo" style="--hero-img:url('/images/lavender-closeup.jpg')">
    <div class="wrap hero__inner">
      <p class="eyebrow">{SITE.descriptor}</p>
      <h1>Lavender syrup, made for the glass.</h1>
      <p class="hero__lede">
        One bottle, four ingredients, and a whole field behind it. Lavender and butterfly pea
        flower, steeped and strained by hand. A natural blue that blooms to pink with a squeeze
        of citrus. No essential oils, no artificial colour.
      </p>
      <div class="cta-row"><BuyButton /></div>
    </div>
  </section>

  <section class="section wrap split">
    <div>
      <p class="eyebrow">What is in it</p>
      <h2>Four ingredients. Nothing to hide.</h2>
      <p>
        Lavender, butterfly pea flower, cane sugar and water. That is the whole list. The lavender is
        our own <strong>Grosso</strong>, grown on the Naramata property and steeped as whole buds,
        never an extract or a flavouring. We strain it and balance it so the lavender reads floral,
        never soapy. That balance is the hard part, and the part we obsess over.
      </p>
      <p>
        Butterfly pea flower gives the syrup a natural deep blue, no dye. Pour it over ice and it is
        blue; add a squeeze of lemon, a splash of tonic or a pour of sparkling wine and it blooms to
        pink. Grosso is bold enough to carry a gin and tonic or a vodka soda where a softer lavender
        would simply disappear.
      </p>
    </div>
    <img class="media" src="/images/lavender-bundle-lake.jpg" width="1125" height="1500"
      loading="lazy" decoding="async"
      alt="A freshly cut bundle of Grosso lavender on the deck, Okanagan Lake in the distance" />
  </section>

  <section class="section section--surface">
    <div class="wrap">
      <p class="eyebrow">How to use it</p>
      <h2>Floral, not fussy.</h2>
      <div class="cards">
        <article class="card"><h3>The colour-change one</h3><p>Our signature <a href="/recipes/naramata-sunset">Naramata Sunset</a> pours blue and turns sunset-pink as you add the lemon.</p></article>
        <article class="card"><h3>Gin or vodka</h3><p>Bold enough for both. Try a <a href="/recipes/lavender-gin-fizz">Gin Fizz</a>, a <a href="/recipes/lavender-french-75">French 75</a> or a <a href="/recipes/lavender-moscow-mule">vodka mule</a>.</p></article>
        <article class="card"><h3>No alcohol</h3><p>Every pour works as a mocktail. A <a href="/recipes/lavender-lemonade">Lavender Lemonade</a> or an <a href="/recipes/lavender-latte">iced latte</a> is the easy one.</p></article>
      </div>
    </div>
  </section>

  <section class="section wrap center">
    <h2>Coming to Amazon.ca this season.</h2>
    <p class="lede" style="margin-inline:auto;">A small first batch. <a href="/#launch">Leave your email</a> and we will tell you the day it goes live.</p>
    <div class="cta-row" style="justify-content:center;"><BuyButton /></div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(productLd)} />
</Base>
